<Application x:Class="BrakeCalibrator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BrakeCalibrator"
             xmlns:conv="clr-namespace:BrakeCalibrator.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:StringToVisibilityConverter x:Key="StringToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
