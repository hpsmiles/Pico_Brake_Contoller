<Window x:Class="BrakeCalibrator.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="340"
        WindowStartupLocation="CenterOwner"
        Background="#161B22"
        ResizeMode="NoResize"
        TextElement.Foreground="#E6EDF3">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptText" Text="Enter value:"
                   Foreground="#8B949E" FontSize="12" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="InputBox" FontSize="14"
                 Padding="8,6" Margin="0,0,0,12"
                 KeyDown="OnInputKeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="OK" Style="{StaticResource AccentButton}"
                    Click="OnOk" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
