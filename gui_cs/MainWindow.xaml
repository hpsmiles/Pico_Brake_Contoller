<Window x:Class="BrakeCalibrator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BrakeCalibrator.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="Pico Brake Controller" Height="820" Width="1320"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        TextElement.Foreground="#E6EDF3">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Grid legend marker templates -->
            <ControlTemplate x:Key="LegendMarker">
                <Rectangle Width="14" Height="3" RadiusX="1.5" Fill="{Binding Fill}"/>
            </ControlTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Menu -->
            <RowDefinition Height="*"/>       <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ MENU BAR ═══════════════════ -->
        <Menu Grid.Row="0" Padding="4,2">
            <MenuItem Header="_File">
                <MenuItem Header="_Load from Pico" Command="{Binding LoadFromPicoCommand}"/>
                <MenuItem Header="_Save to Pico" Command="{Binding SaveToPicoCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Profiles">
                <MenuItem Header="_Save Profile..." Command="{Binding SaveProfileCommand}"/>
                <MenuItem Header="_Load Profile" Command="{Binding LoadProfileCommand}"/>
                <MenuItem Header="_Delete Profile" Command="{Binding DeleteProfileCommand}"/>
                <Separator/>
                <MenuItem Header="_Refresh List" Command="{Binding RefreshProfilesCommand}"/>
            </MenuItem>
            <MenuItem Header="_Device">
                <MenuItem Header="_Refresh Devices" Command="{Binding RefreshDevicesCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
        <Grid Grid.Row="1" Margin="8,4,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>   <!-- Chart area -->
                <ColumnDefinition Width="6"/>                   <!-- Splitter -->
                <ColumnDefinition Width="320" MinWidth="280"/>  <!-- Settings panel -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LEFT: CHARTS ══════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>     <!-- Brake chart -->
                    <RowDefinition Height="8"/>     <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Throttle chart (collapsible) -->
                </Grid.RowDefinitions>

                <!-- Brake Chart Card -->
                <Border Grid.Row="0" Background="#161B22" CornerRadius="8"
                        BorderBrush="#30363D" BorderThickness="1" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Chart Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,4">
                            <TextBlock Text="⚡ BRAKE" FontSize="14" FontWeight="Bold"
                                       Foreground="#58A6FF" FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="  Real-time Signal Monitor" FontSize="11"
                                       Foreground="#6E7681" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#4488FF" Margin="0,0,4,0"/>
                                <TextBlock Text="Raw" FontSize="10" Foreground="#8B949E" Margin="0,0,10,0"/>
                                <Ellipse Width="8" Height="8" Fill="#3FB950" Margin="0,0,4,0"/>
                                <TextBlock Text="Calibrated" FontSize="10" Foreground="#8B949E" Margin="0,0,10,0"/>
                                <Ellipse Width="8" Height="8" Fill="#F85149" Margin="0,0,4,0"/>
                                <TextBlock Text="Game" FontSize="10" Foreground="#8B949E"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Live Chart -->
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding Series}"
                                            XAxes="{Binding BrakeXAxis}"
                                            YAxes="{Binding BrakeYAxis}"
                                            Background="Transparent" Margin="4,0,4,4"
                                           AnimationsSpeed="0"/>
                    </Grid>
                </Border>

                <!-- Throttle Chart Card -->
                <Border Grid.Row="2" Background="#161B22" CornerRadius="8"
                        BorderBrush="#30363D" BorderThickness="1" Padding="0"
                        Visibility="{Binding ThrottleEnabled, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <Grid Height="160">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,8,16,4">
                            <TextBlock Text="🎯 THROTTLE" FontSize="13" FontWeight="Bold"
                                       Foreground="#D29922" FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#FF8800" Margin="0,0,4,0"/>
                                <TextBlock Text="Raw" FontSize="10" Foreground="#8B949E" Margin="0,0,10,0"/>
                                <Ellipse Width="8" Height="8" Fill="#FFCC00" Margin="0,0,4,0"/>
                                <TextBlock Text="Calibrated" FontSize="10" Foreground="#8B949E"/>
                            </StackPanel>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ThrottleSeries}"
                                            XAxes="{Binding ThrottleXAxis}"
                                            YAxes="{Binding ThrottleYAxis}"
                                            Background="Transparent" Margin="4,0,4,4"
                                           AnimationsSpeed="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════ SPLITTER ══════════════ -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- ══════════════ RIGHT: SETTINGS PANEL ══════════════ -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="#0D1117" Padding="0">
                <StackPanel Margin="4,0">

                    <!-- ──── DEVICE ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="🔗 DEVICE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#58A6FF" Margin="0,0,0,6" FontFamily="Segoe UI Semibold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Devices}"
                                          SelectedIndex="{Binding SelectedDeviceIndex}"
                                          DisplayMemberPath="ProductName"/>
                                <Button Grid.Column="1" Content="⟳" Width="30" Margin="4,0,0,0"
                                        Command="{Binding RefreshDevicesCommand}" ToolTip="Refresh devices"/>
                            </Grid>
                            <TextBlock Text="{Binding StatusText}" FontSize="10"
                                       Foreground="#8B949E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ──── AUTO CALIBRATION ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="🎯 AUTO CALIBRATION" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#3FB950" Margin="0,0,0,6" FontFamily="Segoe UI Semibold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="Calibrate Brake" Style="{StaticResource AccentButton}"
                                        Command="{Binding StartAutoCalCommand}" CommandParameter="0"
                                        IsEnabled="{Binding IsAutoCalibrating, Converter={StaticResource InvertBool}, FallbackValue=True}"
                                        Padding="10,4" Margin="0,0,4,0"/>
                                <Button Content="Calibrate Throttle"
                                        Command="{Binding StartAutoCalCommand}" CommandParameter="1"
                                        Visibility="{Binding ThrottleEnabled, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                                        IsEnabled="{Binding IsAutoCalibrating, Converter={StaticResource InvertBool}, FallbackValue=True}"
                                        Padding="10,4"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CalStatus}" FontSize="11" Foreground="#D29922"
                                       TextWrapping="Wrap" Visibility="{Binding CalStatus, Converter={StaticResource StringToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- ──── BRAKE SETTINGS ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="🛞 BRAKE SETTINGS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#58A6FF" Margin="0,0,0,6" FontFamily="Segoe UI Semibold"/>

                            <!-- Manual calibration row -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding RawMin, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="Bold" TextAlignment="Center"/>
                                <Button Grid.Column="1" Content="Min" Width="36" Margin="2,0"
                                        Command="{Binding SetRawMinToCurrentCommand}" FontSize="10" Padding="2,2"/>
                                <TextBox Grid.Column="2" Text="{Binding RawMax, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="Bold" TextAlignment="Center"/>
                                <Button Grid.Column="3" Content="Max" Width="36" Margin="2,0"
                                        Command="{Binding SetRawMaxToCurrentCommand}" FontSize="10" Padding="2,2"/>
                            </Grid>

                            <!-- Curve -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Curve" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CurveOptions}" SelectedItem="{Binding Curve}"/>
                                <Button Grid.Column="2" Content="✏️" Width="30" Margin="4,0,0,0"
                                        Command="{Binding OpenCurveEditorCommand}" ToolTip="Curve Editor"/>
                            </Grid>

                            <!-- Sliders -->
                            <StackPanel Margin="0,0,0,2">
                                <!-- Smoothing -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Smoothing" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="0.95" TickFrequency="0.05"
                                            Value="{Binding Smoothing}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Smoothing, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>

                                <!-- Deadzone -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Deadzone" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1000" TickFrequency="10"
                                            Value="{Binding Deadzone}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Deadzone}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>

                                <!-- Saturation -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Saturation" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" TickFrequency="0.05"
                                            Value="{Binding Saturation}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Saturation, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>

                                <!-- Bite Point -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bite Point" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="0.5" TickFrequency="0.01"
                                            Value="{Binding BitePoint}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding BitePoint, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <!-- Oversample + Invert -->
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Oversample" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding OversampleOptions}" SelectedItem="{Binding Oversample}"/>
                                <CheckBox Grid.Column="2" Content="Invert" IsChecked="{Binding InvertBrake}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ──── THROTTLE SETTINGS ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            Visibility="{Binding ThrottleEnabled, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🏎️ THROTTLE SETTINGS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#D29922" FontFamily="Segoe UI Semibold"/>
                                <CheckBox Grid.Column="1" Content="Enabled" IsChecked="{Binding ThrottleEnabled}"
                                          Foreground="#8B949E" FontSize="10"/>
                            </Grid>

                            <!-- Manual calibration row -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ThrottleRawMin, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="Bold" TextAlignment="Center"/>
                                <Button Grid.Column="1" Content="Min" Width="36" Margin="2,0"
                                        Command="{Binding SetThrottleRawMinToCurrentCommand}" FontSize="10" Padding="2,2"/>
                                <TextBox Grid.Column="2" Text="{Binding ThrottleRawMax, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="Bold" TextAlignment="Center"/>
                                <Button Grid.Column="3" Content="Max" Width="36" Margin="2,0"
                                        Command="{Binding SetThrottleRawMaxToCurrentCommand}" FontSize="10" Padding="2,2"/>
                            </Grid>

                            <!-- Curve -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Curve" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CurveOptions}" SelectedItem="{Binding ThrottleCurve}"/>
                                <Button Grid.Column="2" Content="✏️" Width="30" Margin="4,0,0,0"
                                        Command="{Binding OpenThrottleCurveEditorCommand}" ToolTip="Curve Editor"/>
                            </Grid>

                            <!-- Sliders -->
                            <StackPanel Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Smoothing" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="0.95" TickFrequency="0.05"
                                            Value="{Binding ThrottleSmoothing}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ThrottleSmoothing, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Deadzone" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1000" TickFrequency="10"
                                            Value="{Binding ThrottleDeadzone}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ThrottleDeadzone}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Saturation" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" TickFrequency="0.05"
                                            Value="{Binding ThrottleSaturation}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ThrottleSaturation, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bite Point" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="0.5" TickFrequency="0.01"
                                            Value="{Binding ThrottleBitePoint}" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ThrottleBitePoint, StringFormat={}{0:F2}}"
                                               Foreground="#8B949E" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <CheckBox Content="Invert" IsChecked="{Binding ThrottleInvert}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ──── THROTTLE TOGGLE (when disabled, show toggle) ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                            Visibility="{Binding ThrottleEnabled, Converter={StaticResource InvertBoolToVis}, FallbackValue=Visible}">
                        <CheckBox Content="🏎️ Enable Throttle" IsChecked="{Binding ThrottleEnabled}"
                                  Foreground="#D29922" FontWeight="SemiBold" FontSize="12"/>
                    </Border>

                    <!-- ──── PROFILES ──── -->
                    <Border Background="#1C2333" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="📂 PROFILES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#BC8CFF" Margin="0,0,0,6" FontFamily="Segoe UI Semibold"/>
                            <ComboBox ItemsSource="{Binding Profiles}" SelectedIndex="{Binding SelectedProfileIndex}"
                                      Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save" Command="{Binding SaveProfileCommand}" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                                <Button Content="Load" Command="{Binding LoadProfileCommand}" Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                                <Button Content="Delete" Style="{StaticResource DangerButton}"
                                        Command="{Binding DeleteProfileCommand}" Padding="8,3" FontSize="10"/>
                                <Button Content="⟳" Command="{Binding RefreshProfilesCommand}"
                                        Width="24" Margin="4,0,0,0" FontSize="10" Padding="2,2" ToolTip="Refresh"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ──── SAVE TO PICO ──── -->
                    <Button Content="💾  Save to Pico" Style="{StaticResource AccentButton}"
                            Command="{Binding SaveToPicoCommand}"
                            FontSize="14" Padding="16,10" Margin="0,4,0,4"
                            FontWeight="SemiBold"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════ STATUS BAR ═══════════════════ -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding DriveInfo}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding AxisDebugText}" FontSize="10" Foreground="#8B949E"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
